# Sentry DSN for crash reporting
# Get your DSN from https://sentry.io
EXPO_PUBLIC_SENTRY_DSN=

# Sentry auth token for uploading debug symbols (source map symbolication)
# Required only for production builds. Get from https://sentry.io/settings/account/api/auth-tokens/
# When set, add @sentry/react-native/expo to plugins in app.json:
#   ["@sentry/react-native/expo", { "organization": "your-org", "project": "your-project" }]
SENTRY_AUTH_TOKEN=
