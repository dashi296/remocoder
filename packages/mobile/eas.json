{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760517051"
      },
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "distribution": "store"
      },
      "env": {
        "APP_VARIANT": "production"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "production"
      }
    }
  }
}
